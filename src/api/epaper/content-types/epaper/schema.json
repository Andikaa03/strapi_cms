{
  "kind": "collectionType",
  "collectionName": "epapers",
  "info": {
    "singularName": "epaper",
    "pluralName": "epapers",
    "displayName": "ePaper",
    "description": "Newspaper ePaper pages grouped by date and edition"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {

    "publishDate": {
      "type": "date",
      "required": true
    },
    "edition": {
      "type": "enumeration",
      "enum": [
        "edition-1",
        "edition-2"
      ],
      "default": "edition-1",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "zones": {
      "type": "component",
      "repeatable": true,
      "component": "epaper.zone"
    }
  }
}
