    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "article": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::article.article"
    },
    "facebook": {
      "type": "integer",
      "default": 0
    },
    "twitter": {
      "type": "integer",
      "default": 0
    },
    "linkedin": {
      "type": "integer",
      "default": 0
    },
    "pinterest": {
      "type": "integer",
      "default": 0
    },
    "whatsapp": {
      "type": "integer",
      "default": 0
    },
    "likes": {
      "type": "integer",
      "default": 0
    }
  }
}
